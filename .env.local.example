# Outrank Next.js Blog integration API key.
# Server-only — never expose with NEXT_PUBLIC_ prefix.
# Get it from outrank.so → Integrations → Next.js Blog → Create integration.
OUTRANK_BLOG_API_KEY=

# Gmail automation for outreach.
# Preferred for Google Workspace senders: base64-encoded service account JSON
# with domain-wide delegation, impersonating the sender mailbox.
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_IMPERSONATE_USER=tong@notfair.co

# Legacy fallback only: user OAuth refresh token. Workspace accounts may fail
# with invalid_rapt and require browser reauth, so avoid for automation.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
